{% liquid
  assign section_token = section.id | replace: '_', '-'
  assign tabs_count = 0
  assign default_tab_key = ''

  for block in section.blocks
    if block.type == 'tab_item'
      assign tabs_count = tabs_count | plus: 1
      assign current_tab_key = block.settings.tab_key | strip

      if current_tab_key == blank
        assign current_tab_key = block.id
      endif

      if default_tab_key == blank
        assign default_tab_key = current_tab_key
      endif

      if block.settings.default_open
        assign default_tab_key = current_tab_key
      endif
    endif
  endfor
%}

{% capture tab_image_sizes %}(max-width: 749px) {% if tabs_count > 0 %}{{ 100.0 | divided_by: tabs_count }}{% else %}100{% endif %}vw, 33vw{% endcapture %}

{% style %}
  .mp-tabs-showcase--{{ section_token }} {
  --mp-bg: {{ section.settings.section_background }};
  --mp-card-bg: {{ section.settings.card_background }};
  --mp-soft-bg: {{ section.settings.soft_background }};
  --mp-border: {{ section.settings.border_color }};
  --mp-text: {{ section.settings.text_color }};
  --mp-muted: {{ section.settings.muted_text_color }};
  --mp-accent: {{ section.settings.accent_color }};
  --mp-accent-contrast: {{ section.settings.accent_text_color }};
  --mp-radius: {{ section.settings.border_radius }}px;
  --mp-shadow: 0 14px 40px rgba(20, 20, 20, 0.08);
  --mp-shadow-soft: 0 8px 24px rgba(20, 20, 20, 0.06);
  --mp-max-width: {{ section.settings.max_width }}px;
  --mp-tab-hover-shift: -7px;
  --mp-tab-active-shift: -30px;
  --mp-tab-shadow: drop-shadow(0 16px 24px rgba(20, 20, 20, 0.14));
  --mp-tab-hover-shadow: drop-shadow(0 24px 34px rgba(20, 20, 20, 0.18));
  --mp-tab-active-shadow: drop-shadow(0 34px 46px rgba(20, 20, 20, 0.26));

  position: relative;
  z-index: 0;
  isolation: isolate;
  background: transparent;
  color: var(--mp-text);
  padding: 24px 0;
}

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__inner {
    max-width: var(--mp-max-width);
    margin: 0 auto;
    padding: 0 16px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__intro {
    margin-bottom: 22px;
    text-align: center;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__heading {
    margin: 0 0 10px;
    font-size: clamp(24px, 3vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--mp-text);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__subtext {
    max-width: 820px;
    margin: 0 auto;
    color: var(--mp-muted);
    font-size: 16px;
    line-height: 1.6;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__subtext p {
    margin: 0;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tabs {
    display: grid;
    grid-template-columns: repeat({% if tabs_count > 0 %}{{ tabs_count }}{% else %}1{% endif %}, minmax(0, 1fr));
    gap: 12px;
    align-items: end;
    position: relative;
    z-index: 0;
    margin-bottom: 14px;
    padding: 12px 0 4px;
    overflow: visible;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab-wrap {
    min-width: 0;
    padding: 0;
    overflow: visible;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    appearance: none;
    cursor: pointer;
    color: inherit;
    text-align: left;
    overflow: visible;
    transform: translateY(0);
    transform-origin: center bottom;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    will-change: transform;
    transition:
      transform 0.22s ease,
      opacity 0.2s ease,
      box-shadow 0.2s ease;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab:focus-visible {
    outline: 2px solid var(--mp-accent);
    outline-offset: 4px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab-media {
    position: relative;
    overflow: visible;
    border-radius: 10px;
    aspect-ratio: {{ section.settings.tab_image_aspect_ratio }};
    background: transparent;
    margin-bottom: 0;
    box-shadow: none;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab-title {
    margin: 10px 0 4px;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 700;
    color: var(--mp-text);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab-subtitle {
    margin: 0;
    font-size: 13px;
    line-height: 1.45;
    color: var(--mp-muted);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab:hover {
    transform: translateY(var(--mp-tab-hover-shift));
    z-index: 2;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab.is-active {
    transform: translateY(var(--mp-tab-active-shift));
    z-index: 4;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__content-panel {
    background: var(--mp-card-bg);
    border: 1px solid var(--mp-border);
    border-radius: calc(var(--mp-radius) + 8px);
    box-shadow: var(--mp-shadow);
    padding: 22px;
    margin-bottom: 20px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__content-top,
  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__content-bottom {
    display: grid;
    gap: 14px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__content-top {
    margin-bottom: 20px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__content-bottom {
    margin-top: 20px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__block-heading {
    margin: 0;
    color: var(--mp-text);
    letter-spacing: -0.02em;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__block-heading--h2 {
    font-size: clamp(24px, 3vw, 34px);
    line-height: 1.08;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__block-heading--h3 {
    font-size: clamp(20px, 2.5vw, 28px);
    line-height: 1.14;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__block-heading--h4 {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.2;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__block-text {
    color: var(--mp-muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__block-text p:first-child {
    margin-top: 0;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__block-text p:last-child {
    margin-bottom: 0;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    transition:
      transform 0.18s ease,
      opacity 0.18s ease,
      box-shadow 0.18s ease,
      background-color 0.18s ease,
      color 0.18s ease;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__button:hover {
    transform: translateY(-1px);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__button:focus-visible {
    outline: 2px solid var(--mp-accent);
    outline-offset: 3px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__button--primary {
    background: var(--mp-accent);
    color: var(--mp-accent-contrast);
    box-shadow: 0 10px 22px rgba(20, 20, 20, 0.12);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__button--secondary {
    background: transparent;
    color: var(--mp-text);
    border: 1px solid var(--mp-border);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__products {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
    border: 1px solid var(--mp-border);
    border-radius: calc(var(--mp-radius) + 2px);
    background: var(--mp-card-bg);
    padding: 12px;
    box-shadow: var(--mp-shadow-soft);
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product:hover {
    transform: translateY(-2px);
    border-color: var(--mp-accent);
    box-shadow: 0 16px 28px rgba(20, 20, 20, 0.10);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product:focus-visible {
    outline: 2px solid var(--mp-accent);
    outline-offset: 3px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product-media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: calc(var(--mp-radius) - 2px);
    background: var(--mp-soft-bg);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product-media img,
  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product-media svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product-title {
    margin: 0;
    font-size: 14px;
    line-height: 1.3;
    font-weight: 600;
    color: var(--mp-text);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product-price {
    margin: 0;
    font-size: 16px;
    line-height: 1.1;
    font-weight: 800;
    color: var(--mp-text);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__compare-wrap {
    margin-top: 18px;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__compare-description {
    padding: 18px 18px 0;
    margin-bottom: 18px;
    color: var(--mp-muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__compare-description p:first-child {
    margin-top: 0;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__compare-description p:last-child {
    margin-bottom: 0;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__compare-panel {
    border: 1px solid var(--mp-border);
    border-radius: calc(var(--mp-radius) + 8px);
    background: var(--mp-card-bg);
    box-shadow: var(--mp-shadow);
    overflow: hidden;
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__empty {
    padding: 18px;
    border: 1px dashed var(--mp-border);
    border-radius: calc(var(--mp-radius) + 2px);
    background: var(--mp-soft-bg);
    color: var(--mp-muted);
    text-align: center;
  }

  .ai-bundle-comparison-wrap--{{ section_token }} {
    padding: 0;
  }

  .ai-bundle-comparison--{{ section_token }} {
    display: block;
    width: {{ section.settings.compare_desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    --first-col: 42%;
    --surface-main: {{ section.settings.compare_background_color }};
    --surface-soft: {{ section.settings.compare_category_background }};
    --surface-col-a: rgba(255, 248, 244, 0.96);
    --surface-col-b: rgba(255, 255, 255, 0.98);
    --line-soft: {{ section.settings.compare_border_color }};
    --line-main: {{ section.settings.compare_border_color }};
    --text-strong: {{ section.settings.compare_text_color }};
  }

  .ai-bundle-comparison__wrapper--{{ section_token }} {
    border: 1px solid var(--line-main);
    border-radius: {{ section.settings.compare_border_radius | plus: 10 }}px;
    overflow-x: auto;
    overflow-y: visible;
    background: var(--surface-main);
    box-shadow: 0 18px 50px rgba(39, 24, 18, 0.08);
  }

  .ai-bundle-comparison__table--{{ section_token }} {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
    table-layout: fixed;
    background: transparent;
  }

  .ai-bundle-comparison__table--{{ section_token }} th,
  .ai-bundle-comparison__table--{{ section_token }} td {
    overflow: hidden;
    word-break: break-word;
  }

  .ai-bundle-comparison__table--{{ section_token }} th:first-child,
  .ai-bundle-comparison__table--{{ section_token }} td:first-child {
    width: var(--first-col);
  }

  .ai-bundle-comparison__table--{{ section_token }} th:not(:first-child),
  .ai-bundle-comparison__table--{{ section_token }} td:not(:first-child) {
    border-left: 1px solid var(--line-soft);
  }

  .ai-bundle-comparison__table--{{ section_token }} thead th {
    box-shadow: inset 0 -1px 0 rgba(18, 18, 18, 0.06);
  }

  .ai-bundle-comparison__header-cell--{{ section_token }} {
    padding: 8px 4px 10px;
    text-align: center;
    vertical-align: top;
    color: {{ section.settings.compare_text_color }};
    border-bottom: 1px solid var(--line-main);
    background: {{ section.settings.compare_header_background }};
  }

  .ai-bundle-comparison__header-cell--{{ section_token }}:first-child {
    text-align: left;
    padding-left: 14px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-strong);
  }

  .ai-bundle-comparison__table--{{ section_token }} thead th:nth-child(even),
  .ai-bundle-comparison__table--{{ section_token }} tbody td:nth-child(even) {
    background: var(--surface-col-b);
  }

  .ai-bundle-comparison__table--{{ section_token }} thead th:nth-child(odd):not(:first-child),
  .ai-bundle-comparison__table--{{ section_token }} tbody td:nth-child(odd):not(:first-child) {
    background: var(--surface-col-a);
  }

  .ai-bundle-comparison__bundle-header--{{ section_token }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 6px 4px 8px;
    border-radius: 12px;
    background: linear-gradient(180deg, #ffffff 0%, #fdf7f4 100%);
    border: 1px solid rgba(18, 18, 18, 0.05);
    box-shadow: 0 6px 16px rgba(39, 24, 18, 0.06);
    min-height: 100%;
  }

  .ai-bundle-comparison__bundle-imglink--{{ section_token }} {
    display: block;
    width: 100%;
    line-height: 0;
    text-decoration: none;
  }

  .ai-bundle-comparison__bundle-image--{{ section_token }} {
    width: calc(100% - 2px);
    height: auto;
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    object-fit: cover;
    display: block;
    margin: 0 auto;
    border: 1px solid rgba(18, 18, 18, 0.06);
    box-shadow: 0 6px 16px rgba(39, 24, 18, 0.08);
    background: #fff;
  }

  .ai-bundle-comparison__bundle-namelink--{{ section_token }} {
    font-weight: 700;
    font-size: 12px;
    line-height: 1.08;
    color: {{ section.settings.compare_text_color }};
    text-align: center;
    max-width: 100%;
    text-decoration: none;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .ai-bundle-comparison__bundle-namelink--{{ section_token }}:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ai-bundle-comparison__bundle-price--{{ section_token }} {
    font-weight: 800;
    font-size: 18px;
    line-height: 1;
    text-align: center;
    color: var(--text-strong);
    margin: 0;
    padding: 0 2px;
    letter-spacing: -0.03em;
  }

  .ai-bundle-comparison__bundle-link--{{ section_token }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 34px;
    height: 34px;
    padding: 0 10px;
    border: none;
    border-radius: 999px;
    background: {{ section.settings.compare_button_background }};
    color: {{ section.settings.compare_button_text_color }};
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 10px 20px rgba(18, 18, 18, 0.16);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background-color 0.18s ease,
      opacity 0.18s ease;
  }

  .ai-bundle-comparison__bundle-link--{{ section_token }}:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 24px rgba(18, 18, 18, 0.18);
    background: {{ section.settings.compare_button_hover_background }};
  }

  .ai-bundle-comparison__bundle-link--{{ section_token }}[disabled] {
    opacity: 0.55;
    cursor: not-allowed;
    box-shadow: none;
  }

  .ai-bundle-comparison__cart-icon--{{ section_token }} {
    width: 14px;
    height: 14px;
    display: block;
  }

  .ai-bundle-comparison__row--{{ section_token }} {
    border-bottom: 1px solid var(--line-main);
  }

  .ai-bundle-comparison__category-cell--{{ section_token }} {
    padding: 12px 10px;
    font-weight: 600;
    color: {{ section.settings.compare_text_color }};
    background: {{ section.settings.compare_category_background }};
    vertical-align: top;
    border-right: 1px solid var(--line-soft);
  }

  .ai-bundle-comparison__category-title--{{ section_token }} {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    margin-bottom: 8px;
    border-radius: 999px;
    background: #f6ebe6;
    color: #86665d;
    font-size: 11px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ai-bundle-comparison__item-cell--{{ section_token }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 4px 0;
  }

  .ai-bundle-comparison__product-link--{{ section_token }} {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-bundle-comparison__product-link--{{ section_token }}:hover .ai-bundle-comparison__product-name--{{ section_token }} {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ai-bundle-comparison__product-image--{{ section_token }} {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid rgba(18, 18, 18, 0.06);
    box-shadow: 0 8px 18px rgba(39, 24, 18, 0.08);
    background: #fff;
  }

  .ai-bundle-comparison__product-name--{{ section_token }} {
    font-size: 13px;
    color: var(--text-strong);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .ai-bundle-comparison__check-cell--{{ section_token }} {
    padding: 12px 6px;
    text-align: center;
    vertical-align: middle;
  }

  .ai-bundle-comparison__checkmark--{{ section_token }},
  .ai-bundle-comparison__empty--{{ section_token }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 999px;
  }

  .ai-bundle-comparison__checkmark--{{ section_token }} {
    color: {{ section.settings.compare_checkmark_color }};
    background: rgba(0, 128, 96, 0.10);
    box-shadow: inset 0 0 0 1px rgba(0, 128, 96, 0.14);
  }

  .ai-bundle-comparison__empty--{{ section_token }} {
    color: {{ section.settings.compare_empty_color }};
    background: rgba(18, 18, 18, 0.04);
    font-size: 13px;
    line-height: 1;
  }

  @media screen and (max-width: 1140px) {
    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__products {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__products {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .mp-tabs-showcase--{{ section_token }} {
      --mp-tab-hover-shift: -4px;
      --mp-tab-active-shift: -12px;
      --mp-tab-shadow: drop-shadow(0 10px 16px rgba(20, 20, 20, 0.10));
      --mp-tab-hover-shadow: drop-shadow(0 14px 20px rgba(20, 20, 20, 0.13));
      --mp-tab-active-shadow: drop-shadow(0 18px 28px rgba(20, 20, 20, 0.18));
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__inner {
      padding: 0 6px;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__compare-wrap {
      width: 100vw;
      margin-top: 14px;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      padding: 0 4px;
      box-sizing: border-box;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__compare-panel {
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      overflow: visible;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tabs {
      grid-template-columns: repeat({% if tabs_count > 0 %}{{ tabs_count }}{% else %}1{% endif %}, minmax(0, 1fr));
      width: 100%;
      margin-left: 0;
      margin-right: 0;
      overflow-x: visible;
      overflow-y: visible;
      gap: 6px;
      padding: 12px 0 4px;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab-wrap {
      padding: 0;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__content-panel {
      padding: 16px;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__products {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product {
      padding: 10px;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product-title {
      font-size: 12px;
    }

    .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__product-price {
      font-size: 14px;
    }

    .ai-bundle-comparison--{{ section_token }} {
      width: 100%;
      --first-col: 34%;
      box-sizing: border-box;
    }

    .ai-bundle-comparison__wrapper--{{ section_token }} {
      overflow: visible;
    }

    .ai-bundle-comparison__table--{{ section_token }} {
      min-width: 0;
    }

    .ai-bundle-comparison__header-cell--{{ section_token }} {
      padding: 3px 1px 5px;
    }

    .ai-bundle-comparison__header-cell--{{ section_token }}:first-child {
      padding-left: 6px;
      font-size: 10px;
      line-height: 1.1;
    }

    .ai-bundle-comparison__bundle-header--{{ section_token }} {
      gap: 3px;
      padding: 3px 1px 4px;
      border-radius: 6px;
      box-shadow: none;
    }

    .ai-bundle-comparison__bundle-image--{{ section_token }} {
      width: 100%;
      border-radius: 5px;
      box-shadow: none;
    }

    .ai-bundle-comparison__bundle-namelink--{{ section_token }} {
      font-size: 7px;
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    .ai-bundle-comparison__bundle-price--{{ section_token }} {
      font-size: 10px;
      line-height: 1;
    }

    .ai-bundle-comparison__bundle-link--{{ section_token }} {
      min-width: 24px;
      height: 24px;
      padding: 0 4px;
      box-shadow: none;
    }

    .ai-bundle-comparison__cart-icon--{{ section_token }} {
      width: 10px;
      height: 10px;
    }

    .ai-bundle-comparison__category-cell--{{ section_token }} {
      padding: 6px 3px;
    }

    .ai-bundle-comparison__check-cell--{{ section_token }} {
      padding: 6px 2px;
    }

    .ai-bundle-comparison__category-title--{{ section_token }} {
      font-size: 7px;
      padding: 2px 4px;
      margin-bottom: 4px;
    }

    .ai-bundle-comparison__item-cell--{{ section_token }} {
      gap: 5px;
      padding: 1px 0;
    }

    .ai-bundle-comparison__product-link--{{ section_token }} {
      gap: 5px;
    }

    .ai-bundle-comparison__product-image--{{ section_token }} {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      box-shadow: none;
    }

    .ai-bundle-comparison__product-name--{{ section_token }} {
      font-size: 8px;
      line-height: 1.1;
    }

    .ai-bundle-comparison__checkmark--{{ section_token }},
    .ai-bundle-comparison__empty--{{ section_token }} {
      width: 18px;
      height: 18px;
    }

    .ai-bundle-comparison__checkmark--{{ section_token }} svg {
      width: 11px;
      height: 11px;
    }
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab:hover .mp-tabs-showcase__tab-media img,
  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab:hover .mp-tabs-showcase__tab-media svg {
    filter: var(--mp-tab-hover-shadow);
    -webkit-filter: var(--mp-tab-hover-shadow);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab.is-active .mp-tabs-showcase__tab-media img,
  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab.is-active .mp-tabs-showcase__tab-media svg {
    filter: var(--mp-tab-active-shadow);
    -webkit-filter: var(--mp-tab-active-shadow);
  }

  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab-media img,
  .mp-tabs-showcase--{{ section_token }} .mp-tabs-showcase__tab-media svg {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    object-fit: cover;
    filter: var(--mp-tab-shadow);
    -webkit-filter: var(--mp-tab-shadow);
    transform: translateZ(0);
    -webkit-transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    will-change: transform, filter;
    contain: paint;
    transition: filter 0.22s ease;
  }
{% endstyle %}

<div
  class="mp-tabs-showcase mp-tabs-showcase--{{ section_token }}"
  data-default-tab="{{ default_tab_key }}"
  data-active-tab="{{ default_tab_key }}"
  {{ section.shopify_attributes }}
>
  <div class="mp-tabs-showcase__inner">
    {% if section.settings.section_heading != blank or section.settings.section_subtext != blank %}
      <div class="mp-tabs-showcase__intro">
        {% if section.settings.section_heading != blank %}
          <h2 class="mp-tabs-showcase__heading">{{ section.settings.section_heading }}</h2>
        {% endif %}

        {% if section.settings.section_subtext != blank %}
          <div class="mp-tabs-showcase__subtext">{{ section.settings.section_subtext }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if tabs_count == 0 %}
      <div class="mp-tabs-showcase__empty">
        Добавь хотя бы один блок типа «Tab image».
      </div>
    {% else %}
      <div class="mp-tabs-showcase__tabs" role="tablist" aria-label="Tabs">
        {% for block in section.blocks %}
          {% if block.type == 'tab_item' %}
            {% liquid
              assign tab_key = block.settings.tab_key | strip
              if tab_key == blank
                assign tab_key = block.id
              endif

              assign tab_dom_key = tab_key | handleize
              assign is_active = false

              if tab_key == default_tab_key
                assign is_active = true
              endif
            %}

            <div
              class="mp-tabs-showcase__tab-wrap"
              data-editor-tab-key="{{ tab_key }}"
              {{ block.shopify_attributes }}
            >
              <button
                type="button"
                id="mp-tab-{{ section_token }}-{{ tab_dom_key }}"
                class="mp-tabs-showcase__tab{% if is_active %} is-active{% endif %}"
                data-tab-button="{{ tab_key }}"
                role="tab"
                aria-controls="mp-panel-{{ section_token }}-{{ tab_dom_key }}"
                aria-selected="{% if is_active %}true{% else %}false{% endif %}"
                tabindex="{% if is_active %}0{% else %}-1{% endif %}"
              >
                <div class="mp-tabs-showcase__tab-media">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1000
                      | image_tag:
                        loading: 'lazy',
                        widths: '320,480,640,800,1000',
                        sizes: tab_image_sizes,
                        alt: block.settings.title
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                  {% endif %}
                </div>

                {% if block.settings.title != blank %}
                  <p class="mp-tabs-showcase__tab-title">{{ block.settings.title }}</p>
                {% endif %}

                {% if block.settings.subtitle != blank %}
                  <p class="mp-tabs-showcase__tab-subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}
              </button>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% for tab_block in section.blocks %}
        {% if tab_block.type == 'tab_item' %}
          {% liquid
            assign tab_key = tab_block.settings.tab_key | strip
            if tab_key == blank
              assign tab_key = tab_block.id
            endif

            assign tab_dom_key = tab_key | handleize
            assign is_active = false

            if tab_key == default_tab_key
              assign is_active = true
            endif
          %}

          <div
            id="mp-panel-{{ section_token }}-{{ tab_dom_key }}"
            class="mp-tabs-showcase__content-panel"
            data-tab-content="{{ tab_key }}"
            data-editor-tab-key="{{ tab_key }}"
            role="tabpanel"
            aria-labelledby="mp-tab-{{ section_token }}-{{ tab_dom_key }}"
            {% unless is_active %}hidden{% endunless %}
          >
            {% assign positions = 'top,bottom' | split: ',' %}
            {% for position in positions %}
              <div class="mp-tabs-showcase__content-{{ position }}">
                {% for block in section.blocks %}
                  {% assign block_tab_key = block.settings.tab_key | strip %}
                  {% if block_tab_key == tab_key and block.settings.position == position %}
                    {% case block.type %}
                      {% when 'heading_block' %}
                        {% if block.settings.heading != blank %}
                          <div data-editor-tab-key="{{ tab_key }}" {{ block.shopify_attributes }}>
                            <{{ block.settings.heading_tag }} class="mp-tabs-showcase__block-heading mp-tabs-showcase__block-heading--{{ block.settings.heading_tag }}">
                              {{ block.settings.heading }}
                            </{{ block.settings.heading_tag }}>
                          </div>
                        {% endif %}

                      {% when 'text_block' %}
                        {% if block.settings.text != blank %}
                          <div class="mp-tabs-showcase__block-text" data-editor-tab-key="{{ tab_key }}" {{ block.shopify_attributes }}>
                            {{ block.settings.text }}
                          </div>
                        {% endif %}

                      {% when 'button_block' %}
                        {% if block.settings.label != blank %}
                          <div class="mp-tabs-showcase__button-row" data-editor-tab-key="{{ tab_key }}" {{ block.shopify_attributes }}>
                            <a
                              href="{% if block.settings.link != blank %}{{ block.settings.link }}{% else %}#{% endif %}"
                              class="mp-tabs-showcase__button mp-tabs-showcase__button--{{ block.settings.style }}"
                            >
                              {{ block.settings.label }}
                            </a>
                          </div>
                        {% endif %}
                    {% endcase %}
                  {% endif %}
                {% endfor %}
              </div>

              {% if position == 'top' %}
                {% liquid
                  assign visible_products_count = 0
                %}
                <div class="mp-tabs-showcase__products">
                  {% for block in section.blocks %}
                    {% assign block_tab_key = block.settings.tab_key | strip %}
                    {% if block.type == 'product_card' and block.settings.product != blank and block_tab_key == tab_key and visible_products_count < 5 %}
                      {% assign visible_products_count = visible_products_count | plus: 1 %}
                      {% assign product = block.settings.product %}

                      <a
                        href="{{ product.url }}"
                        class="mp-tabs-showcase__product"
                        data-editor-tab-key="{{ tab_key }}"
                        {{ block.shopify_attributes }}
                      >
                        <div class="mp-tabs-showcase__product-media">
                          {% if product.featured_image %}
                            {{
                              product.featured_image
                              | image_url: width: 700
                              | image_tag:
                                loading: 'lazy',
                                widths: '180,240,320,400,520,700',
                                sizes: '(max-width: 749px) 44vw, 18vw',
                                alt: product.title
                            }}
                          {% else %}
                            {{ 'product-1' | placeholder_svg_tag }}
                          {% endif %}
                        </div>

                        <p class="mp-tabs-showcase__product-title">{{ product.title }}</p>
                        <p class="mp-tabs-showcase__product-price">{{ product.price | money }}</p>
                      </a>
                    {% endif %}
                  {% endfor %}
                </div>

                {% if visible_products_count == 0 %}
                  <div class="mp-tabs-showcase__empty" style="margin-top: 14px;">
                    Для этой вкладки пока не добавлены товары.
                  </div>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      {% endfor %}

      <div class="mp-tabs-showcase__compare-wrap" data-compare-wrap>
        {% for tab_block in section.blocks %}
          {% if tab_block.type == 'tab_item' %}
            {% liquid
              assign tab_key = tab_block.settings.tab_key | strip
              if tab_key == blank
                assign tab_key = tab_block.id
              endif

              assign compare_description = tab_block.settings.compare_description
              assign compare_table = tab_block.settings.compare_table
              assign has_compare_table = false
              assign compare_table_header_products = blank
              assign compare_table_rows = blank
              assign compare_rows_count = 0
              assign compare_products_count = 0

              if compare_table != blank
                assign has_compare_table = true
                assign compare_table_header_products = compare_table.header_products.value
                assign compare_table_rows = compare_table.rows.value

                if compare_table_rows != blank
                  for compare_row in compare_table_rows
                    if compare_row != blank
                      assign compare_rows_count = compare_rows_count | plus: 1
                    endif
                  endfor
                endif

                if compare_table_header_products != blank
                  for bundle_product in compare_table_header_products limit: 5
                    if bundle_product != blank
                      assign compare_products_count = compare_products_count | plus: 1
                    endif
                  endfor
                endif
              endif
              assign has_compare = false
              if compare_rows_count > 0 and compare_products_count > 0
                assign has_compare = true
              endif

              assign is_active = false
              if tab_key == default_tab_key
                assign is_active = true
              endif
            %}

            <div
              class="mp-tabs-showcase__compare-panel ai-bundle-comparison-wrap--{{ section_token }}"
              data-compare-panel="{{ tab_key }}"
              data-editor-tab-key="{{ tab_key }}"
              data-has-compare-table="{% if has_compare_table %}true{% else %}false{% endif %}"
              data-has-compare="{% if has_compare %}true{% else %}false{% endif %}"
              {% unless is_active %}hidden{% endunless %}
            >
              <div class="ai-bundle-comparison--{{ section_token }}">
                {% if compare_description != blank %}
                  <div class="mp-tabs-showcase__compare-description" data-editor-tab-key="{{ tab_key }}">
                    {{ compare_description }}
                  </div>
                {% endif %}

                {% if has_compare %}
                  <div class="ai-bundle-comparison__wrapper--{{ section_token }}">
                    <table class="ai-bundle-comparison__table--{{ section_token }}">
                      <thead>
                        <tr>
                          <th class="ai-bundle-comparison__header-cell--{{ section_token }}">
                            {{ section.settings.compare_table_heading }}
                          </th>

                          {% for bundle_product in compare_table_header_products limit: 5 %}
                            <th class="ai-bundle-comparison__header-cell--{{ section_token }}">
                              {% if bundle_product != blank %}
                                {% assign bundle_image_class = 'ai-bundle-comparison__bundle-image--' | append: section_token %}

                                <div class="ai-bundle-comparison__bundle-header--{{ section_token }}">
                                  {% if bundle_product.featured_image %}
                                    <a href="{{ bundle_product.url }}" class="ai-bundle-comparison__bundle-imglink--{{ section_token }}">
                                      {{
                                        bundle_product.featured_image
                                        | image_url: width: 900
                                        | image_tag:
                                          class: bundle_image_class,
                                          loading: 'lazy',
                                          widths: '240,360,480,600,750,900',
                                          sizes: '(max-width: 749px) 22vw, (max-width: 1200px) 14vw, 180px',
                                          alt: bundle_product.title
                                      }}
                                    </a>
                                  {% endif %}

                                  <a href="{{ bundle_product.url }}" class="ai-bundle-comparison__bundle-namelink--{{ section_token }}">
                                    {{ bundle_product.title }}
                                  </a>

                                  <div class="ai-bundle-comparison__bundle-price--{{ section_token }}">
                                    {{ bundle_product.price | money }}
                                  </div>

                                </div>
                              {% endif %}
                            </th>
                          {% endfor %}
                        </tr>
                      </thead>
                      <tbody>
                        {% for compare_row in compare_table_rows %}
                          {% if compare_row != blank %}
                            {% liquid
                              assign row_category_name = compare_row.category_title.value
                              assign row_product = compare_row.item_product.value
                              assign row_custom_label = compare_row.custom_label.value
                              assign row_display_name = ''
                              assign row_included_products = compare_row.included_in_products.value

                              if row_custom_label != blank
                                assign row_display_name = row_custom_label
                              elsif row_product != blank
                                assign row_display_name = row_product.title
                              endif
                            %}

                            <tr class="ai-bundle-comparison__row--{{ section_token }}" data-editor-tab-key="{{ tab_key }}">
                              <td class="ai-bundle-comparison__category-cell--{{ section_token }}">
                                {% if section.settings.compare_show_category_title and row_category_name != blank %}
                                  <div class="ai-bundle-comparison__category-title--{{ section_token }}">{{ row_category_name }}</div>
                                {% endif %}

                                {% if row_display_name != blank %}
                                  <div class="ai-bundle-comparison__item-cell--{{ section_token }}">
                                    {% if row_product %}
                                      <a href="{{ row_product.url }}" class="ai-bundle-comparison__product-link--{{ section_token }}">
                                        {% if row_product.featured_image %}
                                          <img
                                            src="{{ row_product.featured_image | image_url: width: 140 }}"
                                            alt="{{ row_display_name | escape }}"
                                            class="ai-bundle-comparison__product-image--{{ section_token }}"
                                            loading="lazy"
                                            width="64"
                                            height="64"
                                          >
                                        {% endif %}
                                        <span class="ai-bundle-comparison__product-name--{{ section_token }}">{{ row_display_name }}</span>
                                      </a>
                                    {% else %}
                                      <div class="ai-bundle-comparison__product-name--{{ section_token }}">{{ row_display_name }}</div>
                                    {% endif %}
                                  </div>
                                {% endif %}
                              </td>

                              {% for bundle_product in compare_table_header_products limit: 5 %}
                                {% liquid
                                  assign is_included = false

                                  if bundle_product != blank and row_included_products != blank
                                    for included_product in row_included_products
                                      if included_product != blank and included_product.id == bundle_product.id
                                        assign is_included = true
                                        break
                                      endif
                                    endfor
                                  endif
                                %}

                                <td class="ai-bundle-comparison__check-cell--{{ section_token }}">
                                  {% if bundle_product != blank %}
                                    {% if is_included %}
                                      <span class="ai-bundle-comparison__checkmark--{{ section_token }}" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                          <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                      </span>
                                    {% else %}
                                      <span class="ai-bundle-comparison__empty--{{ section_token }}" aria-hidden="true">&mdash;</span>
                                    {% endif %}
                                  {% endif %}
                                </td>
                              {% endfor %}
                            </tr>
                          {% endif %}
                        {% endfor %}
                        </tbody>
                      </table>
                </div>
                {% else %}
                  <div class="mp-tabs-showcase__empty">
                    {% if has_compare_table %}
                      This tab has a compare table assigned, but it does not contain synced rows yet.
                    {% else %}
                      Assign a compare table to this tab before running compare sync.
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  (function () {
    if (!window.MPTabsShowcase) {
      window.MPTabsShowcase = (function () {
        function getTabButtons(root) {
          return Array.prototype.slice.call(root.querySelectorAll('[data-tab-button]'));
        }

        function getContentPanels(root) {
          return Array.prototype.slice.call(root.querySelectorAll('[data-tab-content]'));
        }

        function getComparePanels(root) {
          return Array.prototype.slice.call(root.querySelectorAll('[data-compare-panel]'));
        }

        function initTabsShowcase(root) {
          if (!root || root.dataset.initialized === '1') return;
          root.dataset.initialized = '1';

          var tabButtons = getTabButtons(root);
          var contentPanels = getContentPanels(root);
          var comparePanels = getComparePanels(root);
          var compareWrap = root.querySelector('[data-compare-wrap]');

          if (!tabButtons.length) return;

          var defaultKey = root.getAttribute('data-default-tab') || tabButtons[0].getAttribute('data-tab-button');
          var activeKey = defaultKey;

          function updateCompareState() {
            if (compareWrap) {
              compareWrap.hidden = false;

              comparePanels.forEach(function (panel) {
                var sameKey = panel.getAttribute('data-compare-panel') === activeKey;
                panel.hidden = !sameKey;
              });
            }
          }

          function activateTab(key, options) {
            options = options || {};
            activeKey = key;
            root.setAttribute('data-active-tab', key);

            tabButtons.forEach(function (button) {
              var isActive = button.getAttribute('data-tab-button') === key;
              button.classList.toggle('is-active', isActive);
              button.setAttribute('aria-selected', isActive ? 'true' : 'false');
              button.setAttribute('tabindex', isActive ? '0' : '-1');

              if (isActive && options.focusButton) {
                button.focus();
              }
            });

            contentPanels.forEach(function (panel) {
              panel.hidden = panel.getAttribute('data-tab-content') !== key;
            });

            updateCompareState();
          }

          function activateByIndex(index, focusButton) {
            if (index < 0 || index >= tabButtons.length) return;
            var button = tabButtons[index];
            if (!button) return;

            activateTab(button.getAttribute('data-tab-button'), { focusButton: focusButton === true });
          }

          tabButtons.forEach(function (button, index) {
            button.addEventListener('click', function () {
              activateTab(button.getAttribute('data-tab-button'));
            });

            button.addEventListener('keydown', function (event) {
              switch (event.key) {
                case 'ArrowRight':
                case 'Right':
                  event.preventDefault();
                  activateByIndex((index + 1) % tabButtons.length, true);
                  break;

                case 'ArrowLeft':
                case 'Left':
                  event.preventDefault();
                  activateByIndex((index - 1 + tabButtons.length) % tabButtons.length, true);
                  break;

                case 'Home':
                  event.preventDefault();
                  activateByIndex(0, true);
                  break;

                case 'End':
                  event.preventDefault();
                  activateByIndex(tabButtons.length - 1, true);
                  break;
              }
            });
          });

          root._mpActivateTab = activateTab;
          activateTab(defaultKey);
        }

        function initAll(scope) {
          var roots = (scope || document).querySelectorAll('.mp-tabs-showcase');
          roots.forEach(function (root) {
            initTabsShowcase(root);
          });
        }

        function bindGlobalEvents() {
          if (window.MPTabsShowcaseEventsBound) return;
          window.MPTabsShowcaseEventsBound = true;

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function () {
              initAll(document);
            });
          } else {
            initAll(document);
          }

          document.addEventListener('shopify:section:load', function (event) {
            initAll(event.target);
          });

          document.addEventListener('shopify:block:select', function (event) {
            var root = event.target.closest('.mp-tabs-showcase');
            if (!root) return;

            if (typeof root._mpActivateTab !== 'function') {
              initTabsShowcase(root);
            }

            var keyedElement = event.target.closest('[data-editor-tab-key]');
            if (!keyedElement) return;

            var key = keyedElement.getAttribute('data-editor-tab-key');
            if (key && typeof root._mpActivateTab === 'function') {
              root._mpActivateTab(key);
            }
          });
        }

        bindGlobalEvents();

        return {
          initAll: initAll
        };
      })();
    } else {
      window.MPTabsShowcase.initAll(document);
    }
  })();
</script>

{% schema %}
{
  "name": "MamaPack tabs showcase",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Главный заголовок",
      "default": "Gotowe torby do szpitala"
    },
    {
      "type": "richtext",
      "id": "section_subtext",
      "label": "Текст под заголовком",
      "default": "<p>Wybierz zestaw dla mamy, dla noworodka lub dla mamy i dziecka.</p>"
    },
    {
      "type": "text",
      "id": "compare_show_label",
      "label": "Текст кнопки показать сравнение",
      "default": "Porównaj zawartość"
    },
    {
      "type": "text",
      "id": "compare_hide_label",
      "label": "Текст кнопки скрыть сравнение",
      "default": "Ukryj porównanie"
    },
    {
      "type": "text",
      "id": "compare_table_heading",
      "label": "Заголовок таблицы сравнения",
      "default": "Porównanie zawartości"
    },
    {
      "type": "text",
      "id": "tab_image_aspect_ratio",
      "label": "Соотношение сторон изображений табов",
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Максимальная ширина секции",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
