{% liquid
  assign section_key = section.id | replace: '_', '-'
  assign group_title = section.settings.title | strip
  assign main_collection = section.settings.main_collection
  assign main_url = section.settings.main_link
  if main_collection != blank
    assign main_url = main_collection.url
  endif
  if group_title == blank and main_collection != blank
    assign group_title = main_collection.title
  endif
%}
{% style %}
  .mp-category-card--{{ section_key }} {
    --mp-card-bg: {{ section.settings.card_background }};
    --mp-soft-bg: {{ section.settings.soft_background }};
    --mp-border: {{ section.settings.border_color }};
    --mp-text: {{ section.settings.text_color }};
    --mp-accent: {{ section.settings.accent_color }};
    --mp-radius: {{ section.settings.border_radius }}px;
    --mp-shadow-alpha: {{ section.settings.shadow_opacity | divided_by: 100.0 }};
    color: var(--mp-text);
    padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto 0 0;
  }
  .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__inner { margin: 0 0 0 auto; }
  .mp-category-card--{{ section_key }} .mp-category-card__panel {
    display: grid;
    grid-template-columns: minmax(260px, 34%) minmax(0, 1fr);
    min-height: 196px;
    overflow: hidden;
    border: 1px solid var(--mp-border);
    border-radius: var(--mp-radius);
    background: var(--mp-card-bg);
    box-shadow: 0 12px 34px rgba(35, 28, 24, var(--mp-shadow-alpha));
  }
  .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__panel { grid-template-columns: minmax(0, 1fr) minmax(260px, 34%); }
  .mp-category-card--{{ section_key }} .mp-category-card__media {
    position: relative;
    min-height: 196px;
    overflow: hidden;
    background: var(--mp-soft-bg);
  }
  .mp-category-card--{{ section_key }} .mp-category-card__image,
  .mp-category-card--{{ section_key }} .mp-category-card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 196px;
    object-fit: cover;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__placeholder {
    background: linear-gradient(135deg, #f8eee7 0%, #fdfaf7 52%, #ece6dd 100%);
  }
  .mp-category-card--{{ section_key }} .mp-category-card__content {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 22px;
    padding: 30px 30px 28px 36px;
  }
  .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__media { order: 2; }
  .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__content { order: 1; padding: 30px 36px 28px 30px; }
  .mp-category-card--{{ section_key }} .mp-category-card__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
  }
  .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__head { grid-template-columns: auto minmax(0, 1fr); }
  .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__main-link { order: 1; }
  .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__title-group { order: 2; justify-self: end; }
  .mp-category-card--{{ section_key }} .mp-category-card__title-group { display: flex; min-width: 0; gap: 18px; align-items: center; }
  .mp-category-card--{{ section_key }} .mp-category-card__number {
    display: inline-grid;
    width: 50px;
    height: 50px;
    place-items: center;
    border-radius: 50%;
    background: var(--mp-soft-bg);
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__title {
    margin: 0;
    font-size: 30px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__main-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    min-height: 46px;
    padding: 0 19px;
    border-radius: 14px;
    background: var(--mp-soft-bg);
    color: var(--mp-accent);
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.16s ease, background 0.16s ease;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__main-link:hover {
    background: #f1e2d5;
    transform: translateY(-1px);
  }
  .mp-category-card--{{ section_key }} .mp-category-card__main-link svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__links {
    display: grid;
    grid-template-columns: repeat(2, minmax(170px, 1fr));
    gap: 18px 44px;
    align-content: center;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__item {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 16px;
    color: var(--mp-text);
    font-size: 18px;
    line-height: 1.25;
    text-decoration: none;
  }
  .mp-category-card--{{ section_key }} a.mp-category-card__item:hover .mp-category-card__label {
    border-bottom-color: currentColor;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__icon {
    display: inline-flex;
    flex: 0 0 32px;
    color: var(--mp-accent);
  }
  .mp-category-card--{{ section_key }} .mp-category-card__icon svg {
    width: 32px;
    height: 32px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }
  .mp-category-card--{{ section_key }} .mp-category-card__label {
    min-width: 0;
    overflow-wrap: anywhere;
    border-bottom: 1px solid rgba(75, 62, 54, 0.35);
  }
  @media screen and (max-width: 749px) {
    .mp-category-card--{{ section_key }} { padding-left: 8px; padding-right: 8px; }
    .mp-category-card--{{ section_key }} .mp-category-card__panel {
      grid-template-columns: minmax(112px, 34%) minmax(0, 1fr);
      min-height: 142px; border-radius: min(var(--mp-radius), 18px);
    }
    .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__panel { grid-template-columns: minmax(0, 1fr) minmax(112px, 34%); }
    .mp-category-card--{{ section_key }} .mp-category-card__media,
    .mp-category-card--{{ section_key }} .mp-category-card__image,
    .mp-category-card--{{ section_key }} .mp-category-card__placeholder { min-height: 142px; }
    .mp-category-card--{{ section_key }} .mp-category-card__content { gap: 10px; padding: 14px 10px; }
    .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__content { padding: 14px 10px; }
    .mp-category-card--{{ section_key }} .mp-category-card__head {
      grid-template-columns: minmax(0, 1fr) auto; gap: 6px;
    }
    .mp-category-card--{{ section_key }}.mp-category-card--mirrored .mp-category-card__head { grid-template-columns: auto minmax(0, 1fr); }
    .mp-category-card--{{ section_key }} .mp-category-card__title-group { gap: 6px; }
    .mp-category-card--{{ section_key }} .mp-category-card__number { width: 26px; height: 26px; font-size: 13px; }
    .mp-category-card--{{ section_key }} .mp-category-card__title { font-size: clamp(14px, 3.8vw, 18px); }
    .mp-category-card--{{ section_key }} .mp-category-card__main-link { gap: 4px; min-height: 26px; padding: 0 7px; border-radius: 8px; font-size: 10px; }
    .mp-category-card--{{ section_key }} .mp-category-card__main-link svg { width: 10px; height: 10px; }
    .mp-category-card--{{ section_key }} .mp-category-card__links {
      grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 9px 12px;
    }
    .mp-category-card--{{ section_key }} .mp-category-card__item { gap: 8px; font-size: clamp(12px, 3.2vw, 18px); }
    .mp-category-card--{{ section_key }} .mp-category-card__icon { flex-basis: 22px; }
    .mp-category-card--{{ section_key }} .mp-category-card__icon svg { width: 22px; height: 22px; }
  }
{% endstyle %}
<section class="mp-category-card mp-category-card--{{ section_key }}{% if section.settings.mirror_layout %} mp-category-card--mirrored{% endif %}">
  <div class="mp-category-card__inner">
    <div class="mp-category-card__panel">
      <div class="mp-category-card__media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag: class: 'mp-category-card__image', loading: 'lazy', sizes: '(min-width: 990px) 430px, 100vw', widths: '360, 540, 720, 900' }}
        {% else %}
          <div class="mp-category-card__placeholder" aria-hidden="true"></div>
        {% endif %}
      </div>
      <div class="mp-category-card__content">
        <div class="mp-category-card__head">
          <div class="mp-category-card__title-group">
            <span class="mp-category-card__number">{{ section.settings.group_number | escape }}</span>
            <h2 class="mp-category-card__title">{{ group_title | escape }}</h2>
          </div>
          {% if section.settings.main_button_label != blank and main_url != blank %}
            <a class="mp-category-card__main-link" href="{{ main_url }}">
              {{ section.settings.main_button_label | escape }}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
            </a>
          {% endif %}
        </div>
        <div class="mp-category-card__links">
          {% for block in section.blocks %}
            {% liquid
              assign item_collection = block.settings.collection
              assign item_url = block.settings.link
              assign item_label = block.settings.label | strip
              if item_collection != blank
                assign item_url = item_collection.url
              endif
              if item_label == blank and item_collection != blank
                assign item_label = item_collection.title
              endif
            %}
            {% if item_label != blank %}
              {% if item_url != blank %}
                <a class="mp-category-card__item" href="{{ item_url }}" {{ block.shopify_attributes }}>
              {% else %}
                <span class="mp-category-card__item" {{ block.shopify_attributes }}>
              {% endif %}
                <span class="mp-category-card__icon" aria-hidden="true">
                  {% case block.settings.icon %}
                    {% when 'stand' %}<svg viewBox="0 0 24 24"><path d="M7 5h10" /><path d="M9 5l2 15" /><path d="M15 5l-2 15" /><path d="M9.8 13h4.4" /></svg>
                    {% when 'duck' %}<svg viewBox="0 0 24 24"><path d="M5 15c1 3 3.3 4 6.5 4H15a4 4 0 0 0 4-4v-1h-3.2a3.8 3.8 0 0 1-3.3-2" /><path d="M12.5 12A4.5 4.5 0 0 1 21 9.8l-2.6 1.5" /><path d="M15.8 8.2h.1" /></svg>
                    {% when 'bottle' %}<svg viewBox="0 0 24 24"><path d="M10 3h4" /><path d="M11 3v4l-2 3v9a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-9l-2-3V3" /><path d="M9 13h6" /><path d="M9 16h6" /></svg>
                    {% when 'drop' %}<svg viewBox="0 0 24 24"><path d="M12 3s6 6.4 6 11a6 6 0 0 1-12 0c0-4.6 6-11 6-11Z" /><path d="M9.5 15.5A3 3 0 0 0 12 17" /></svg>
                    {% else %}<svg viewBox="0 0 24 24"><path d="M5 10h14v3a5 5 0 0 1-5 5h-4a5 5 0 0 1-5-5v-3Z" /><path d="M8 10V7a3 3 0 0 1 6 0v1" /><path d="M8 20h8" /></svg>
                  {% endcase %}
                </span>
                <span class="mp-category-card__label">{{ item_label | escape }}</span>
              {% if item_url != blank %}
                </a>
              {% else %}
                </span>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Mamapack category card",
  "enabled_on": { "templates": ["*"] },
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "group_number", "label": "Group number", "default": "1" },
    { "type": "text", "id": "title", "label": "Group title", "default": "KAPIEL" },
    { "type": "collection", "id": "main_collection", "label": "Main button collection" },
    { "type": "url", "id": "main_link", "label": "Main button fallback link" },
    { "type": "text", "id": "main_button_label", "label": "Main button label", "default": "Zobacz wszystko" },
    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "mirror_layout", "label": "Mirror layout", "default": false },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 720, "max": 1600, "step": 20, "unit": "px", "default": 1280 },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "border_radius", "label": "Border radius", "min": 8, "max": 32, "step": 2, "unit": "px", "default": 22 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "soft_background", "label": "Soft background", "default": "#f8eee7" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "#eee7e0" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2c2723" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#8a6651" },
    { "type": "range", "id": "shadow_opacity", "label": "Shadow opacity", "min": 0, "max": 18, "step": 1, "unit": "%", "default": 8 }
  ],
  "blocks": [
    {
      "type": "link_item",
      "name": "Sub button",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Wanienki" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "url", "id": "link", "label": "Fallback link" },
        { "type": "select", "id": "icon", "label": "Icon", "default": "bath", "options": [{ "value": "bath", "label": "Bath" }, { "value": "stand", "label": "Stand" }, { "value": "duck", "label": "Toy" }, { "value": "bottle", "label": "Bottle" }, { "value": "drop", "label": "Drop" }] }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mamapack category card",
      "blocks": [{ "type": "link_item", "settings": { "label": "Wanienki", "icon": "bath" } }, { "type": "link_item", "settings": { "label": "Stojaki do wanienek", "icon": "stand" } }, { "type": "link_item", "settings": { "label": "Zabawki do kapieli", "icon": "duck" } }, { "type": "link_item", "settings": { "label": "Artykuly higieniczne", "icon": "bottle" } }]
    }
  ]
}
{% endschema %}
