<div class="baseSettingCustomPage">
  <div class="infoImageDesktop" style="padding-top: 10px; padding-bottom: 0px;">
    <img src="{{"ListBox_desktop-1.jpg" | file_img_url: '2550x577'}}" style="max-width: 100%; height: auto;">
  </div>
  <div class="infoImageMobile" style="padding-top: 10px; padding-bottom: 0px;">
    <img src="{{"mobile.jpg" | file_img_url: '1536x742'}}" style="max-width: 100%; height: auto;">
  </div>

<!-- Триггер-блок для открытия видео -->
<div class="ivm-container" role="region" aria-label="Видеоинструкция">
  <button class="ivm-trigger" type="button" aria-controls="instructionVideoModal" aria-expanded="false">
    <span class="ivm-icon" aria-hidden="true">▶</span>
    <span class="ivm-text">
      <span class="ivm-title">Zobacz szybką instrukcję</span>
      
    </span>
  </button>
</div>

<!-- Модальное окно с видео -->
<div id="instructionVideoModal" class="ivm-modal" aria-hidden="true">
  <div class="ivm-modal__dialog" role="dialog" aria-modal="true" aria-label="Инструкционное видео">
    <button class="ivm-modal__close" type="button" aria-label="Закрыть">×</button>
    <div class="ivm-aspect">
      <video id="ivm-player" class="ivm-video" controls playsinline preload="metadata">
        <!-- Если файл загружен в Settings → Files, используем file_url -->
        <source src="{{ 'Instruction1.mp4' | file_url }}" type="video/mp4">
        <!-- Если храните в assets темы, замените на asset_url:
        <source src="{{ 'Instruction1.mp4' | asset_url }}" type="video/mp4">
        -->
        Ваш браузер не поддерживает воспроизведение видео.
      </video>
    </div>
  </div>
</div>


  <div id="global-modal" class="modal">
    <table style="table-layout: fixed; width: 100%;">
      <tr>
        <td style="width: 100px; height: 100px;">
          <span class="modal-close">&times;</span>
          <div class="modal-content-container">
            <img class="modal-content full-size-image">
            <a class="prev">&#10094;</a>
            <a class="next">&#10095;</a>
          </div>
          <div class="modalCaption modal-caption"></div>
        </td>
      </tr>
      <tr>
        <td style="width: 100px;">
          <div class="modal-thumbnails"></div>
        </td>
      </tr>
    </table>
  </div>

  <div id="productModal" class="pModal">
    <div class="contentMP">
      <span id="closeModalProduct" class="closeMP">&times;</span>
      <h2>Opis</h2>
      <div id="modalDescription" class="descriptionProduct">
        <!-- Динамически загружаемое описание -->
        <p>Load...</p>
      </div>
    </div>
  </div>

  <div class="categorySelectMainButtons">
    {% assign sorted_collections = collections | sort: 'metafields.custom.collectionusertype' | reverse %}
    {% for collection in sorted_collections %}
      {% assign usertype = collection.metafields.custom.collectionusertype %}
      {% if usertype == '1' or usertype == '2' %}
        <button
          name="baseCatButton-{{ usertype }}"
          class="categorySelectMainButton"
          id="categorySelectMainButton-{{ usertype }}"
          onclick="toggleGroup('{{ collection.handle }}', {{ usertype }})"
        >
          {{ collection.title }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

  {% for collection in sorted_collections %}
    {% assign usertype = collection.metafields.custom.collectionusertype %}
    {% if usertype == '1' or usertype == '2' %}
      <div id="group-{{ collection.handle }}" class="product-group">
        {% assign coll_strings = '' %}

        {% for coll in collections %}
          {% if coll.metafields.custom.sortbyvalue %}
            {% assign coll_string = coll.metafields.custom.sortbyvalue
              | append: ','
              | append: coll.handle
              | append: ','
              | append: coll.id
            %}
            {% assign coll_strings = coll_strings | append: coll_string | append: ';' %}
          {% endif %}
        {% endfor %}

        {% assign coll_strings = coll_strings | remove_last: ';' %}
        {% assign coll_array = coll_strings | split: ';' | sort %}

        {% for child_collection in coll_array %}
          {% assign coll = child_collection | split: ',' %}
          {% assign coll_id = coll[2] %}
          {% assign coll_handle = coll[1] %}

          {% assign child_usertype = collections[coll_handle].metafields.custom.collectionusertype %}
          {% if child_usertype contains usertype and child_usertype != usertype %}
            <div class="categoryHeadBody">
              <table class="categoryNameTable">
                <tbody>
                  <tr class="categoryTr">
                    <td class="categoryTd1">
                      {{ collections[coll_handle].title }}
                      <button class="groupInfoButton" onclick="productsGroupInfo('{{ collections[coll_handle].id }}')">
                        ?
                      </button>
                    </td>
                    <td class="categoryTd2">
                      <button
                        class="showCategoryButton"
                        onclick="toggleProducts('{{ collections[coll_handle].handle }}')"
                      >
                        &gt;
                      </button>
                    </td>
                  </tr>
                  <tr id="categoryTr-{{ collections[coll_handle].id }}" class="categoryTrInfo">
                    <td colspan="2" class="categoryTdInfo">
                      <div class="groupInfoDescription">{{ collections[coll_handle].description }}</div>
                    </td>
                  </tr>
                </tbody>
              </table>

              <table class="productsCategoryTable" id="products-{{ collections[coll_handle].handle }}">
                <tbody>
                  {% for product in collections[coll_handle].products %}
                    <tr class="productRow-1">
                      <td class="cbTd">
                        <div class="checkbox-wrapper">
                          <input
                            type="checkbox"
                            class="add-to-cart-checkbox"
                            id="cbProduct-{{ product.id }}"
                            data-variant-id="{{ product.id }}/{{ product.variants.first.id }}"

                            onchange="CheckBoxHandler('{{ product.id }}', '{{ product.variants.first.id }}', 'cbProduct-{{ product.id }}', 'cbProduct-{{ product.id }}-2')"
                          >
                        </div>
                      </td>
                      <td class="imTd">
                        <!-- Изображение продукта с добавленным data-product-handle -->
                        <img
                          src="{{ product.featured_image | img_url: '200x200' }}"
                          alt="{{ product.title | escape }}"
                          class="product-image-thumbnail"
                          data-fullsize-image="{{ product.featured_image | img_url:'1800x2700' }}"
                          style="cursor: pointer;"
                          data-product-id="{{ product.id }}"
                          data-product-handle="{{ product.handle }}"
                        >
                      </td>
                      <td class="product-details">
                        <div>
                          <div style="width: 100%; margin-bottom: 0px;" class="prName">
                            {{ product.title }}
                            <button
                              type="button"
                              class="buttonDescription"
                              onclick="ShowProductDescriprion('{{ product.handle }}')"
                            >
                              ?
                            </button>
                          </div>

                          <div class="prPrice-{{ product.id }}">Cena: {{ product.price | money }}</div>
                        </div>
                        <div class="variantsButtons">
                          {% for variant in product.variants %}
                            {% if variant and variant.title != blank and variant.title != 'Default Title' %}
                              <button
                                type="button"
                                class="variantProduct-{{ product.id }}"
                                id="variantSelectForProductId-{{ product.id }}-{{ variant.id }}"
                                onclick="variantSelect({{ product.id }}, {{ variant.id }})"
                                data-selected-id="0"
                                data-product-id="{{ product.id }}"
                                data-variant-id="{{ variant.id }}"
                                data-variant-price="{{ variant.price }}"
                              >
                                {{ variant.title }}
                              </button>
                            {% endif %}
                          {% endfor %}
                        </div>
                      </td>
                      <td class="product-quantity">
                        <div class="quantity-stepper-{{ product.id }}">
                          <div class="selected-quantity-{{ product.id }}">
                            <button
                              data-product-id="{{ product.id }}"
                              data-plus="0"
                              type="button"
                              class="decrease-quantity"
                              aria-label="Уменьшить количество"
                              onclick="HandleQuantity({{ false }}, {{ product.id }})"
                            >
                              -
                            </button>
                            <input
                              type="number"
                              class="quantity-input"
                              id="quantity-input-{{ product.id }}"
                              value="1"
                              min="1"
                              data-variant-id="{{ product.variants.first.id }}"
                              data-product-price="{{ product.price }}"
                              aria-label="Количество"
                              readonly
                            >
                            <button
                              data-product-id="{{ product.id }}"
                              data-plus="1"
                              type="button"
                              class="increase-quantity"
                              aria-label="Увеличить количество"
                              onclick="HandleQuantity({{ true }}, {{ product.id }})"
                            >
                              +
                            </button>
                          </div>
                          <div class="prTotalCost-{{ product.id }}">{{ product.price | money }}</div>
                        </div>
                      </td>
                    </tr>
                    <tr class="productRow-2">
                      <td class="cbTd">
                        <div class="checkbox-wrapper">
                          <input
                            type="checkbox"
                            class="add-to-cart-checkbox"
                            id="cbProduct-{{ product.id }}-2"
                            data-variant-id="{{ product.id }}/{{ product.variants.first.id }}"
                            onchange="CheckBoxHandler('{{ product.id }}', '{{ product.variants.first.id }}', 'cbProduct-{{ product.id }}-2', 'cbProduct-{{ product.id }}')"
                          >
                        </div>
                      </td>
                      <td class="imTd">
                        <img
                          src="{{ product.featured_image | img_url: '200x200' }}"
                          alt="{{ product.title | escape }}"
                          class="product-image-thumbnail"
                          data-fullsize-image="{{ product.featured_image | img_url:'1800x2700' }}"
                          style="cursor: pointer;"
                          data-product-id="{{ product.id }}"
                          data-product-handle="{{ product.handle }}"
                        >
                      </td>
                      <td class="product-details">
                        <div>
                          <div class="prPrice-{{ product.id }}">Cena: {{ product.price | money }}</div>
                        </div>
                        <div class="variantsButtons">
                          {% for variant in product.variants %}
                            {% if variant and variant.title != blank and variant.title != 'Default Title' %}
                              <button
                                type="button"
                                class="variantProduct-{{ product.id }}"
                                id="variantSelectForProductId-{{ product.id }}-{{ variant.id }}-2"
                                onclick="variantSelect({{ product.id }}, {{ variant.id }})"
                                data-selected-id="0"
                                data-product-id="{{ product.id }}"
                                data-variant-id="{{ variant.id }}"
                                data-variant-price="{{ variant.price }}"
                              >
                                {{ variant.title }}
                              </button>
                            {% endif %}
                          {% endfor %}
                        </div>
                      </td>
                      <td class="product-quantity">
                        <div class="quantity-stepper-{{ product.id }}">
                          <div class="selected-quantity-{{ product.id }}">
                            <button
                              data-product-id="{{ product.id }}"
                              data-plus="0"
                              type="button"
                              class="decrease-quantity"
                              aria-label="Уменьшить количество"
                              onclick="HandleQuantity({{ false }}, {{ product.id }})"
                            >
                              -
                            </button>
                            <input
                              type="number"
                              class="quantity-input"
                              id="quantity-input-{{ product.id }}-2"
                              value="1"
                              min="1"
                              data-variant-id="{{ product.variants.first.id }}"
                              data-product-price="{{ product.price }}"
                              aria-label="Количество"
                              readonly
                            >
                            <button
                              data-product-id="{{ product.id }}"
                              data-plus="1"
                              type="button"
                              class="increase-quantity"
                              aria-label="Увеличить количество"
                              onclick="HandleQuantity({{ true }}, {{ product.id }})"
                            >
                              +
                            </button>
                          </div>
                          <div class="prTotalCost-{{ product.id }}">{{ product.price | money }}</div>
                        </div>
                      </td>
                    </tr>
                    <tr class="productRow-2-2">
                      <td colspan="3">
                        <div class="prNameTitle">
                          {{ product.title }}
                          <button
                            type="button"
                            class="buttonDescription"
                            onclick="ShowProductDescriprion('{{ product.handle }}')"
                          >
                            ?
                          </button>
                        </div>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  {% endfor %}

  <div class="categorySelectMainButtons">
    {% assign sorted_collections = collections | sort: 'metafields.custom.collectionusertype' | reverse %}
    {% for collection in sorted_collections %}
      {% assign usertype = collection.metafields.custom.collectionusertype %}
      {% if usertype == '1' or usertype == '2' %}
        <button
          name="baseCatButton-{{ usertype }}"
          class="categorySelectMainButton"
          id="categorySelectMainButton-{{ usertype }}-2"
          onclick="toggleGroup('{{ collection.handle }}', {{ usertype }})"
        >
          {{ collection.title }}
        </button>
      {% endif %}
    {% endfor %}
  </div>
</div>

<script
  defer
>

(function(){
  var modal   = document.getElementById('instructionVideoModal');
  var trigger = document.querySelector('.ivm-trigger');
  var closeBtn= modal.querySelector('.ivm-modal__close');
  var video   = document.getElementById('ivm-player');

  function openModal(){
    modal.style.display = 'block';
    modal.setAttribute('aria-hidden','false');
    trigger.setAttribute('aria-expanded','true');
    document.body.classList.add('no-scroll');
    try { video.currentTime = 0; video.play(); } catch(e){}
  }

  function closeModal(){
    modal.style.display = 'none';
    modal.setAttribute('aria-hidden','true');
    trigger.setAttribute('aria-expanded','false');
    document.body.classList.remove('no-scroll');
    try { video.pause(); } catch(e){}
  }

  if (trigger) trigger.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', function(e){
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape' && modal.style.display === 'block') closeModal();
  });
})();





  function UpdateListByCart() {
  fetch('/cart.js')
    .then(response => response.json())
    .then(cart => {
      cart.items.forEach(item => {
        UpdateProductByCart(item);
      });
    })
    .catch(error => {
      console.error('Ошибка при обновлении UI корзины:', error);
    });
}

        function UpdateProductByCart(item)
    {

      var quantityEl1 = document.getElementById("quantity-input-" + item.product_id);
      var quantityEl2 = document.getElementById("quantity-input-" + item.product_id +"-2");
      
      quantityEl1.value = item.quantity;
      quantityEl2.value = item.quantity;


      variantSelect(item.product_id, item.variant_id);

      var cbEl1 = document.getElementById("cbProduct-" + item.product_id);
      var cbEl2 = document.getElementById("cbProduct-" + item.product_id +"-2");

      cbEl1.checked = true;
      cbEl2.checked = true;

      document.querySelectorAll('.prTotalCost-' + item.product_id).forEach(function(priceField) {
      priceField.textContent = HandlePriceByLocale(item.line_price);
      });

      enableElements(item.product_id, false);            
    }
 

function productsGroupInfo(GroupId)
  {
    var group = document.getElementById("categoryTr-" + GroupId);
    if (group) {
    if(group.style.display)
    {
      console.log(group.style.display);
    group.style.display = group.style.display === "none" ? "table-row" : "none";
    }
    else
    {
      console.log(group.style.display);
      group.style.display = "table-row";
    }
  }
  }

  function HandleQuantity(plus, productId)
    {
      var element1 = document.getElementById("quantity-input-" + productId);
      var element2 = document.getElementById("quantity-input-" + productId +"-2");

      var value = parseInt(element1.value, 10);
      var userNeedSelect = false;
      
      if(plus)
      {
        value = value + 1;
        userNeedSelect = HandleTotalCostField(value, productId, element1.dataset.productPrice);

        if(userNeedSelect)
        {
          element1.value = value;
          element2.value = value;
        }
        
      } else {
             if (value > 1) {
              value = value - 1;
              userNeedSelect = HandleTotalCostField(value, productId, element1.dataset.productPrice);
                if(userNeedSelect)
                {
                   element1.value = value;
                   element2.value = value;
                }
      }
      }
    }

  function HandleTotalCostField(quantity, productId, prPrice)
    {
      var result = false;
      
      var variant = GetVariantId(productId);

      var variantPrice = variant.variantPrice;
      var variantId = variant.variantId;
      
      if(variantId != "0")
      {
        if(variantPrice === "0")
          variantPrice = prPrice;

          variantPrice = HandlePriceByLocale(variantPrice * quantity);
      
          document.querySelectorAll('.prTotalCost-' + productId).forEach(function(priceField) {
          priceField.textContent = variantPrice;
        });
        result = true;
      }

      return result;
    }


  
function HandlePriceByLocale(price)
    {
      var localePrice = "";

      localePrice = price / 100;
      localePrice = localePrice.toLocaleString('pl-PL', { style: 'currency', currency: 'PLN' });
      
      return localePrice;
    }

function GetVariantId(productId) {
  var variantId = "0";
  var variantPrice = "0";
  
  var buttonsVariant = document.querySelectorAll('.variantProduct-' + productId);
  
  if(buttonsVariant.length > 0)
  {
    buttonsVariant.forEach(function(vButton) {
      if(vButton.dataset.selectedId && vButton.dataset.selectedId !== "0")
      {
        variantId = vButton.dataset.selectedId;
        variantPrice = vButton.dataset.variantPrice;
      }
    });

    if(variantId === "0")
    {
      alert("Najpierw wybierz opcję produktu.");
    }
  } else {
    variantId = "-1";
  }
  return {variantId, variantPrice};
}
  
function variantSelect(productId, variantId) {
  document.querySelectorAll('.variantProduct-' + productId).forEach(function(vButton) {
    vButton.style.backgroundColor = "#FFB7AB";
    vButton.style.color = "#3F575A";
    vButton.dataset.selectedId = 0;
  });

  var element1 = document.getElementById("variantSelectForProductId-" + productId + "-" + variantId);
  var element2 = document.getElementById("variantSelectForProductId-" + productId + "-" + variantId + "-2");
  
  if (element1) {
    element1.style.backgroundColor = "#3F575A";
    element1.style.color = "white";
    element1.dataset.selectedId = variantId;
  }
    if (element2) {
      element2.style.backgroundColor = "#3F575A";
    element2.style.color = "white";
    element2.dataset.selectedId = variantId;
  }

  if(element1 && element2)
  {
      price = HandlePriceByLocale(element1.dataset.variantPrice);

      document.querySelectorAll('.prPrice-' + productId).forEach(function(priceField) {
        priceField.textContent = "Cena: " + price;
      });
    
      var userInputField = document.getElementById("quantity-input-" + productId);

      var totalCost = HandlePriceByLocale(userInputField.value * element1.dataset.variantPrice);
    
      document.querySelectorAll('.prTotalCost-' + productId).forEach(function(totalCostField) {
        totalCostField.textContent = totalCost;
      });
  }
}
  
function toggleGroup(handle, usertype) {
  document.querySelectorAll('.product-group').forEach(function(group) {
    group.style.display = 'none';
    
  });
  document.getElementById("group-" + handle).style.display = "block";

document.querySelectorAll('.categorySelectMainButton').forEach(function(cButton) {
        cButton.style.backgroundColor = "#FFB7AB";
    cButton.style.color = "#3F575A";
    
  });
  
    var element1 = document.getElementById("categorySelectMainButton-" + usertype);

  var element2 = document.getElementById("categorySelectMainButton-" + usertype +"-2");
  
  if (element1) {
    element1.style.backgroundColor = "#3F575A";
    element1.style.color = "white";
  }
    if (element2) {
      element2.style.backgroundColor = "#3F575A";
    element2.style.color = "white";
  }
  
}

function toggleProducts(handle) {
  var element = document.getElementById("products-" + handle);
  if (element) {
    if(element.style.display)
    {
    element.style.display = element.style.display === "none" ? "block" : "none";
    }
    else
    {
      element.style.display = "block";
    }
  }
}

function createCartCountBubble(count) {
  const cartCountBubble = document.createElement('div');
  cartCountBubble.className = 'cart-count-bubble';

  const countSpan = document.createElement('span');
  countSpan.setAttribute('aria-hidden', 'true');
  countSpan.textContent = count;

  const textSpan = document.createElement('span');
  textSpan.className = 'visually-hidden';
  textSpan.textContent = `${count} items`;

  cartCountBubble.appendChild(countSpan);
  cartCountBubble.appendChild(textSpan);

  return cartCountBubble;
}  

function updateCartUI() {
  fetch('/cart.js')
    .then(response => response.json())
    .then(cart => {
      let cartCountBubble = document.querySelector('.cart-count-bubble');
      var totalPriceElement = document.getElementById("cart-total-price");
      var totalPrice = HandlePriceByLocale(cart.total_price);
      if (!cartCountBubble && cart.item_count > 0) {
        const cartElement = document.getElementById('cart-icon-bubble');
        if (cartElement) {
          totalPriceElement.textContent = totalPrice;
        cartElement.appendChild(createCartCountBubble(cart.item_count));
        } else {
        console.error('Элемент корзины не найден');
        }
      }
      if (cartCountBubble) {
        const span = cartCountBubble.querySelector('span[aria-hidden="true"]');
        if (span) {
          totalPriceElement.textContent = totalPrice;
          span.textContent = cart.item_count;
          } else {
          console.error('Элемент не найден');
        }
      }
    })
    .catch(error => {
      console.error('Ошибка при обновлении UI корзины:', error);
    });
}


  async function CheckBoxHandler(productId, firstVariantId, callCbId, secondCbId)
    {
      var callCb = document.getElementById(callCbId);
      var secondCb = document.getElementById(secondCbId);

      disableElementInteraction(".add-to-cart-checkbox");
      
      callCb.disabled  = true;
      secondCb.disabled  = true;
      

      console.log(callCb.checked + " - " + secondCb.checked);
      
       var variantId = GetVariantId(productId).variantId;

    if (variantId === "-1")
    {
      variantId = firstVariantId;
    }
    if(variantId !== "0")
    {

    const quantityInput = callCb.closest('[class^="productRow-"]').querySelector('.quantity-input'); // Находим поле ввода количества
    const quantity = quantityInput ? parseInt(quantityInput.value, 10) : 1; // Получаем значение или ставим 1, если не найдено

     var isSuccess = false;
      
    if (callCb.checked) {
      isSuccess = await addItemToCart(productId, variantId, quantity);
      callCb.checked = isSuccess ? true : false;
    } else {
      isSuccess = await removeItemFromCart(productId, variantId);
      callCb.checked = isSuccess ? false : true;
    }
    } else {
      callCb.checked = false;
    }

secondCb.checked = callCb.checked;

      callCb.disabled  = false;
      secondCb.disabled  = false;

      enableElementInteraction(".add-to-cart-checkbox");
    }


function disabledElementClickEvent()
  {
    alert("Aby zmienić szczegóły, dezaktywuj pole wyboru.");
  }
  
  function enableElements(productId, isEnable)
    {
      if(!isEnable)
      {
          document.querySelectorAll('.variantProduct-' + productId).forEach(function(vButton) {
            vButton.onclick = disabledElementClickEvent;
              if(vButton.dataset.selectedId && vButton.dataset.selectedId === "0")
              {
                vButton.classList.add("disabledElement"); 
              }
            });

          document.querySelectorAll('.selected-quantity-' + productId).forEach(function(stepper) {
            stepper.querySelectorAll('*').forEach(function(vButton) {
              vButton.onclick = disabledElementClickEvent;
              vButton.classList.add("disabledElement");
            });
          });
      }
      else
      {
          document.querySelectorAll('.variantProduct-' + productId).forEach(function(vButton) {
            vButton.onclick = function() {
        variantSelect(vButton.dataset.productId, vButton.dataset.variantId);
      };
              if(vButton.dataset.selectedId && vButton.dataset.selectedId === "0")
                {
                  vButton.classList.remove("disabledElement");
                }
          });

          document.querySelectorAll('.selected-quantity-' + productId).forEach(function(stepper) {
            stepper.querySelectorAll('*').forEach(function(vButton) {
               vButton.onclick = function() {
                 var isPlus;
                 if (vButton.getAttribute('data-plus') === "0") {
                     isPlus = false;
                  } else if(vButton.getAttribute('data-plus') === "1") {
                     isPlus = true;
                    }
                HandleQuantity(isPlus, vButton.dataset.productId);
              };
              vButton.classList.remove("disabledElement");
            });
          });
      }

    }

function disableElementInteraction(selector) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(element => {
    element.classList.add('disable-interactions');
  });
}

function enableElementInteraction(selector) {
  const elements = document.querySelectorAll(selector);
  elements.forEach(element => {
    element.classList.remove('disable-interactions');
  });
}
  
