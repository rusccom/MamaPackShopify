  }
  
  var globalModal = document.getElementById('global-modal');
  var fullImage = globalModal.querySelector('.modal-content.full-size-image');
  var captionText = globalModal.querySelector('.modalCaption');
  var closeModal = globalModal.querySelector('.modal-close');
  var prevBtn = globalModal.querySelector('.prev');
  var nextBtn = globalModal.querySelector('.next');
  var thumbnailsContainer = globalModal.querySelector('.modal-thumbnails');
  var currentIndex = 0;
  var images = [];
  var productImagesCache = {};

  // Собираем все изображения продуктов на странице
  var productImageThumbnails = document.querySelectorAll('.product-image-thumbnail');
  

  productImageThumbnails.forEach(function(imgThumbnail) {
    var productId = imgThumbnail.getAttribute('data-product-id');
    var productHandle = imgThumbnail.getAttribute('data-product-handle');

    imgThumbnail.addEventListener('click', function() {
      if (productImagesCache[productHandle]) {
        images = productImagesCache[productHandle];
        openModal(imgThumbnail);
      } else {
        fetchProductData(productHandle, function(productData) {
          images = productData.images.map(function(image) {
            return {
              src: image,
              thumbnail: image.replace(/(\.[^.]*)$/, '_100x100$1'),
              alt: productData.title
            };
          });
          productImagesCache[productHandle] = images;
          openModal(imgThumbnail);
        });
      }
    });
  });

  

  function openModal(imgThumbnail) {
    currentIndex = images.findIndex(function(img) {
      return img.src === imgThumbnail.getAttribute('data-fullsize-image');
    });

    if (currentIndex === -1) {
      currentIndex = 0;
    }
    scrollPosition = window.pageYOffset || document.documentElement.scrollTop;
    showImage(currentIndex);
    globalModal.style.display = "block";
    document.body.classList.add("no-scroll");

    // Обработчики для стрелок и кнопки закрытия
    prevBtn.onclick = function() {
      var newIndex = (currentIndex - 1 + images.length) % images.length;
      showImage(newIndex);
    };

    nextBtn.onclick = function() {
      var newIndex = (currentIndex + 1) % images.length;
      showImage(newIndex);
    };

    closeModal.onclick = function() {
      closeModalWindow();
    };

    window.onclick = function(event) {
      if (event.target == globalModal) {
        closeModalWindow();
      }
    };

    document.onkeydown = function(e) {
      if (globalModal.style.display === "block") {
        if (e.key === "ArrowLeft") {
          prevBtn.click();
        } else if (e.key === "ArrowRight") {
          nextBtn.click();
        } else if (e.key === "Escape") {
          closeModalWindow();
        }
      }
    };
  }

  function showImage(index) {
    var img = images[index];
    fullImage.src = img.src;
    captionText.innerHTML = img.alt;
    currentIndex = index;

    // Очищаем предыдущие миниатюры
    thumbnailsContainer.innerHTML = '';

    // Создаем миниатюры внутри модального окна
    images.forEach(function(image, idx) {
      var thumb = document.createElement('img');
      thumb.src = image.thumbnail;
      thumb.alt = image.alt;
      thumb.classList.add('modal-thumbnail');
      thumb.dataset.index = idx;

      if (idx === currentIndex) {
        thumb.classList.add('active');
      }

      thumb.onclick = function() {
        showImage(parseInt(this.dataset.index));
      };

      thumbnailsContainer.appendChild(thumb);
    });
  }

  function closeModalWindow() {
    globalModal.style.display = "none";
    document.body.classList.remove("no-scroll");
    // Очищаем обработчики событий
    prevBtn.onclick = null;
    nextBtn.onclick = null;
    closeModal.onclick = null;
    window.onclick = null;
    document.onkeydown = null;
    window.scrollTo(0, scrollPosition);
  }
});

function fetchProductData(handle, callback) {
    fetch('/products/' + handle + '.js')
      .then(response => response.json())
      .then(data => {
        callback(data);
      })
      .catch(error => {
        console.error('Ошибка при получении данных о продукте:', error);
      });
  }
  
